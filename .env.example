# OKX OnchainOS API
OKX_API_KEY=placeholder
OKX_SECRET_KEY=placeholder
OKX_PASSPHRASE=placeholder
OKX_BASE_URL=https://web3.okx.com

# ECDSA Credential Signing
# Generate with: bun run credential:signer:create -- --write-env-file .env.local --include-siwe
ECDSA_PRIVATE_KEY=placeholder
ECDSA_PUBLIC_ADDRESS=placeholder

# x402 Payments (OKX X Layer — zero gas, Chain ID: 196)
# OKX x402 uses stablecoins, NOT OKT
# Choose one of: USDG / USDT / USDC / USDT0
X402_NETWORK=xlayer
X402_CHAIN_ID=196
X402_PAYMENT_TOKEN=USDT0
# Token contract addresses on X Layer (mainnet)
X402_USDG_ADDRESS=0x4ae46a509f6b1d9056937ba4500cb143933d2dc8
X402_USDT_ADDRESS=0x779ded0c9e1022225f8e0630b35a9b54be713736
X402_USDT0_ADDRESS=placeholder
X402_USDC_ADDRESS=0x74b7f16337b8972027f6196a17a631ac6de26d22
# Recipient wallet for x402 payments
X402_RECIPIENT_ADDRESS=placeholder
X402_CREDENTIAL_PRICE_USD=0.50
X402_SCORE_QUERY_PRICE_USD=0.10

# Turso Database
TURSO_DATABASE_URL=placeholder
TURSO_AUTH_TOKEN=placeholder

# SIWE Auth Session
SIWE_SESSION_SECRET=placeholder
SIWE_SESSION_EXPIRY_DAYS=7

# Vercel (set in dashboard, not here)
# VERCEL_URL — auto-set by Vercel

# App
# Development only. Release targets must leave this unset or set a non-mock value.
LOCAL_INTEGRATION_MODE=mock
# Release targets must use the exact HTTPS origin of the deployed app.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=placeholder
